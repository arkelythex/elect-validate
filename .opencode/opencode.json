{
  "name": "elect-validate",
  "version": "1.0.0",
  "description": "Electo - Suite Electoral ONPE",
  "providers": {
    "minimax": {
      "model": "minimax-m2.5-free",
      "temperature": 0.7
    }
  },
  "agents": {
    "default": "agents/default.json",
    "custom": [
      "agents/validator.json",
      "agents/frontend.json"
    ]
  },
  "commands": {
    "validate": "commands/validate.json",
    "build": "commands/build.json",
    "test": "commands/test.json"
  },
  "modes": {
    "default": "modes/local.json"
  },
  "permissions": {
    "autoExecute": false,
    "requireConfirmation": ["delete", "commit"]
  },
  "environment": {
    "GO_VERSION": "1.21",
    "NODE_VERSION": "18"
  }
}
